# ============================================
# EMBEDDING SERVICE CONFIGURATION EXAMPLES
# ============================================
# Prefer the Settings UI for normal configuration. These examples document the
# .env fallback keys used by the runtime.
#
# IMPORTANT URL SEMANTICS
# - EMBEDDING_HOST is the full embedding request endpoint for raw HTTP adapters.
# - Raw adapters (openai, custom, siliconflow, cohere, jina, ollama, vllm) POST to
#   EMBEDDING_HOST verbatim. They do not append /embeddings, /api/embed, or a
#   provider-specific path for you.
# - openrouter and custom_openai_sdk pass EMBEDDING_HOST as the OpenAI SDK
#   base_url; the SDK then creates the embeddings endpoint.
# - azure_openai appends only the api-version query string when configured.
# - aliyun uses the DashScope SDK; EMBEDDING_HOST is normally left unset and the
#   provider default endpoint is used for catalog/versioning metadata.
#
# Supported generic keys:
#   EMBEDDING_BINDING
#   EMBEDDING_MODEL
#   EMBEDDING_API_KEY
#   EMBEDDING_HOST
#   EMBEDDING_DIMENSION
#   EMBEDDING_SEND_DIMENSIONS
#   EMBEDDING_API_VERSION

# ============================================
# OPTION 1: OpenAI
# ============================================
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=sk-your-openai-api-key-here
EMBEDDING_HOST=https://api.openai.com/v1/embeddings
EMBEDDING_DIMENSION=3072
# Optional tri-state: omit for auto, true to always send, false to never send.
# EMBEDDING_SEND_DIMENSIONS=true

# ============================================
# OPTION 2: SiliconFlow
# ============================================
EMBEDDING_BINDING=siliconflow
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_API_KEY=sk-your-siliconflow-api-key-here
EMBEDDING_HOST=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_DIMENSION=4096

# ============================================
# OPTION 3: Ollama (local)
# ============================================
# Requirements:
#   ollama pull nomic-embed-text
#   ollama serve
EMBEDDING_BINDING=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=
EMBEDDING_HOST=http://localhost:11434/api/embed
EMBEDDING_DIMENSION=768
EMBEDDING_SEND_DIMENSIONS=false

# Other Ollama model options:
# EMBEDDING_MODEL=all-minilm              # 384 dimensions, fast
# EMBEDDING_MODEL=all-mpnet-base-v2       # 768 dimensions, balanced
# EMBEDDING_MODEL=mxbai-embed-large       # 1024 dimensions, best quality
# EMBEDDING_MODEL=snowflake-arctic-embed  # 1024 dimensions, good performance

# ============================================
# OPTION 4: Cohere
# ============================================
EMBEDDING_BINDING=cohere
EMBEDDING_MODEL=embed-v4.0
EMBEDDING_API_KEY=your-cohere-api-key-here
EMBEDDING_HOST=https://api.cohere.com/v2/embed
EMBEDDING_DIMENSION=1024

# Cohere model options:
# EMBEDDING_MODEL=embed-v4.0                    # Latest, 256-1536 dims
# EMBEDDING_MODEL=embed-english-v3.0            # English only, 1024 dims
# EMBEDDING_MODEL=embed-multilingual-v3.0       # Multilingual, 1024 dims
# EMBEDDING_MODEL=embed-multilingual-light-v3.0 # Lighter, 384 dims

# ============================================
# OPTION 5: Jina AI
# ============================================
EMBEDDING_BINDING=jina
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_API_KEY=your-jina-api-key-here
EMBEDDING_HOST=https://api.jina.ai/v1/embeddings
EMBEDDING_DIMENSION=1024

# Jina model options:
# EMBEDDING_MODEL=jina-embeddings-v3
# EMBEDDING_MODEL=jina-embeddings-v4

# ============================================
# OPTION 6: vLLM / LM Studio / OpenAI-compatible local server
# ============================================
EMBEDDING_BINDING=vllm
EMBEDDING_MODEL=text-embedding-model
# Leave blank for local servers like LM Studio that reject auth headers.
EMBEDDING_API_KEY=
EMBEDDING_HOST=http://localhost:8000/v1/embeddings
EMBEDDING_DIMENSION=1024

# ============================================
# OPTION 7: Azure OpenAI
# ============================================
# Use the full deployment embeddings endpoint. The runtime adds only the
# api-version query string below.
EMBEDDING_BINDING=azure_openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=your-azure-api-key-here
EMBEDDING_HOST=https://your-resource.openai.azure.com/openai/deployments/your-deployment/embeddings
EMBEDDING_API_VERSION=2024-02-01
EMBEDDING_DIMENSION=3072

# ============================================
# OPTION 8: Aliyun DashScope
# ============================================
# The DashScope native adapter uses the dashscope SDK. EMBEDDING_HOST can be
# omitted; the runtime injects the provider default endpoint for metadata.
EMBEDDING_BINDING=aliyun
EMBEDDING_MODEL=qwen3-vl-embedding
EMBEDDING_API_KEY=your-dashscope-api-key-here
EMBEDDING_HOST=
EMBEDDING_DIMENSION=2560

# ============================================
# OPTION 9: OpenAI SDK-style gateway
# ============================================
# Use when the gateway documents OpenAI SDK usage with a /v1 base URL. The SDK
# appends /embeddings internally.
EMBEDDING_BINDING=custom_openai_sdk
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=sk-your-gateway-key
EMBEDDING_HOST=https://gateway.example.com/v1
EMBEDDING_DIMENSION=3072

# OpenRouter follows the same SDK-style URL rule:
# EMBEDDING_BINDING=openrouter
# EMBEDDING_MODEL=qwen/qwen3-embedding-8b
# EMBEDDING_API_KEY=sk-or-your-openrouter-key
# EMBEDDING_HOST=https://openrouter.ai/api/v1

# ============================================
# PROVIDER API KEY FALLBACKS
# ============================================
# If EMBEDDING_API_KEY is empty, the resolver also checks these provider keys:
#   OPENAI_API_KEY
#   AZURE_OPENAI_API_KEY
#   AZURE_API_KEY
#   COHERE_API_KEY
#   JINA_API_KEY
#   SILICONFLOW_API_KEY
#   DASHSCOPE_API_KEY
#   HOSTED_VLLM_API_KEY
#   OPENROUTER_API_KEY
