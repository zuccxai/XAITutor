# ============================================
# DeepTutor Docker Ignore File
# ============================================
# Excludes files and directories from the Docker build context
# to improve build speed and reduce image size
# ============================================

# ============================================
# Git
# ============================================
.git
.gitignore
.gitattributes

# ============================================
# Documentation
# ============================================
*.md
docs/
assets/
assets/gifs/
assets/figs/
assets/README/

# ============================================
# Python
# ============================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
MANIFEST

# Virtual environments
.env
*.env
!.env.example
env/
venv/
ENV/
.venv/
env.bak/
venv.bak/
DeepTutor.env

# Pytest cache
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ============================================
# Node.js
# ============================================
node_modules/
**/node_modules/
web/node_modules/
web_v1/node_modules/
web_new/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next/
**/.next/
web/.next/
web_v1/.next/
web_new/.next/
out/
**/out/
web/out/
web_v1/out/
web_new/out/
**/.turbo/
**/.eslintcache
**/coverage/
**/playwright-report/
**/test-results/

# Frontend versions not used by the production Docker build
web/
web_v1/

# ============================================
# IDE and Editor
# ============================================
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~
.DS_Store

# ============================================
# Docker
# ============================================
Dockerfile*
docker-compose*.yml
.docker/
.dockerignore

# ============================================
# User Data (will be mounted as volumes)
# ============================================
data/
data/user/
data/knowledge_bases/
data/memory/
data/tutorbot/
run_code_workspace/

