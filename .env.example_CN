# =====================================================================
# DeepTutor 环境变量模板（中文）
# =====================================================================
# 复制本文件为 `.env` 后再填写。
#
# 分组：
#   1. 端口
#   2. LLM                   （聊天必填）
#   3. Embedding             （知识库 / RAG 必填）
#   4. 网页搜索              （可选）
#   5. 网络与前端            （Docker / 远程部署）
#   6. 安全
#   7. 认证与多用户
#   8. PocketBase 边车       （可选的认证 + 存储后端）
#   9. 附件存储              （可选）
#
# 实际启动时只有 LLM_* 是强制的，其它都有默认值。请按需取消注释、填值即可，
# 不需要的留空。

# ---------------------------------------------------------------------
# 1. 端口
# ---------------------------------------------------------------------
BACKEND_PORT=8001
FRONTEND_PORT=3782
# 仅 docker-compose 用来对外暴露 PocketBase 容器的端口。Python 后端连接
# PocketBase 时使用下面的 POCKETBASE_URL，而不是这个变量。
POCKETBASE_PORT=8090

# ---------------------------------------------------------------------
# 2. LLM（必填）
# ---------------------------------------------------------------------
# 支持的 binding：openai, anthropic, deepseek, gemini, azure_openai,
# lm_studio, ollama, vllm, openrouter, siliconflow, dashscope, ...
# 完整列表请运行：`deeptutor provider list`
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-xxx
LLM_HOST=https://api.openai.com/v1
# Azure OpenAI 必填；其它情况留空。
LLM_API_VERSION=
# 可选：控制推理 / 思考强度。
#   DeepSeek：       "high" / "max" 开启思考；"minimal" 关闭
#   OpenAI o 系列：  "low" / "medium" / "high"
# 留空则根据模型名自动判断。
LLM_REASONING_EFFORT=

# ---------------------------------------------------------------------
# 3. Embedding（知识库 / RAG 必填）
# ---------------------------------------------------------------------
# 支持的 binding：openai, azure_openai, cohere, jina, ollama, vllm,
# siliconflow, aliyun, gemini, custom.
#
# 重要（v1.3.0+）：EMBEDDING_HOST 必须填写「完整 endpoint URL」，会被
# 原样调用，不会自动追加路径。（上面的 LLM_HOST 仍然是聊天接口的 base
# URL。）示例：
#   OpenAI:       https://api.openai.com/v1/embeddings
#   Gemini:       https://generativelanguage.googleapis.com/v1beta/openai/embeddings
#   Cohere v4:    https://api.cohere.com/v2/embed
#   Jina:         https://api.jina.ai/v1/embeddings
#   Ollama:       http://localhost:11434/api/embed
#   SiliconFlow:  https://api.siliconflow.cn/v1/embeddings
#   Aliyun:       https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_HOST=https://api.openai.com/v1/embeddings
# Azure embedding 部署需要填写；其它情况留空。
EMBEDDING_API_VERSION=
# 建议留空，让 DeepTutor 在首次「Test connection」成功时自动识别维度。
# 只有需要强制指定 Matryoshka 维度时才手动填写，例如 Qwen3-Embedding 的
# 1024/1536/2048/2560/4096，或 OpenAI text-embedding-3-large 的 3072。
EMBEDDING_DIMENSION=
# 是否在请求体中携带 `dimensions` 参数：
#   true        -> 总是发送（OpenAI text-embedding-3*, Qwen3-Embedding,
#                            Qwen3-VL-Embedding）
#   false       -> 永不发送（如果提供商在收到该参数时返回 HTTP 400，请设为
#                            false）
#   留空 / 未设置 -> 自动：根据模型家族判断
EMBEDDING_SEND_DIMENSIONS=

# 各 embedding 提供商的 API Key 兜底值。当前 embedding profile 没有单独
# 配置 api_key 时会使用这些值；首次打开设置页时也会读取它们，避免重复
# 输入。
SILICONFLOW_API_KEY=
DASHSCOPE_API_KEY=
COHERE_API_KEY=
JINA_API_KEY=
GEMINI_API_KEY=

# ⚠️  Docker + 本地模型（LM Studio / Ollama / vLLM）
# ────────────────────────────────────────────────────────────────────
# 当 DeepTutor 以 Docker 方式运行、而 LLM / embedding 模型运行在宿主机
# 上时：
#   - 不要使用 "localhost" 或 "127.0.0.1"——容器内这些地址指向容器自身，
#     而不是宿主机。
#   - macOS / Windows (Docker Desktop)：
#       http://host.docker.internal:<端口>/v1
#   - Linux：使用宿主机的局域网 IP，例如 http://192.168.1.100:<端口>/v1
#     （或使用 --network=host 启动 Docker）
#
# 示例（LM Studio 监听 1234 端口）:
#   LLM_BINDING=lm_studio
#   LLM_HOST=http://host.docker.internal:1234/v1
#   EMBEDDING_BINDING=lm_studio
#   EMBEDDING_HOST=http://host.docker.internal:1234/v1/embeddings

# ---------------------------------------------------------------------
# 4. 网页搜索（可选）
# ---------------------------------------------------------------------
# 可用 provider：brave, tavily, serper, jina, perplexity, searxng, duckduckgo
SEARCH_PROVIDER=
SEARCH_API_KEY=
# 自托管 SearXNG 必填；其它需要显式 base URL 的提供商可选。
SEARCH_BASE_URL=
# 可选：搜索流量走 HTTP/HTTPS 代理时填写。
SEARCH_PROXY=

# ---------------------------------------------------------------------
# 5. 网络与前端（Docker / 远程部署）
# ---------------------------------------------------------------------
# 远程部署时，浏览器访问后端的公网地址（前端与后端不在同一台机器时使用）。
NEXT_PUBLIC_API_BASE_EXTERNAL=
# 当 Next.js 客户端访问的后端不是 http://localhost:${BACKEND_PORT} 时，
# 使用这个变量覆盖。本地常规启动可留空。
NEXT_PUBLIC_API_BASE=
# 可选：追加到 FastAPI CORS 白名单的额外 Origin（例如自定义域名）。
# localhost / 127.0.0.1 / Docker host 始终被允许。
CORS_ORIGIN=

# ---------------------------------------------------------------------
# 6. 安全
# ---------------------------------------------------------------------
# 是否跳过出站 HTTP 的 TLS 校验。生产环境请保持 false——只在使用本地自签
# 证书或离线测试时才打开。
DISABLE_SSL_VERIFY=false

# ---------------------------------------------------------------------
# 7. 认证与多用户
# ---------------------------------------------------------------------
# 公网部署时设为 true 启用登录；本地 / localhost 使用保持 false 即可，
# 无需登录。
AUTH_ENABLED=false

# 用于签名 JWT 的密钥。留空时 DeepTutor 会在
# multi-user/_system/auth/auth_secret 处生成并复用一个稳定密钥。生产环境
# （尤其是多 worker 部署）建议显式设置。生成命令：
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=

# 登录会话的有效时长，单位：小时。
AUTH_TOKEN_EXPIRE_HOURS=24

# 通过 HTTPS 提供服务时设为 true，让认证 Cookie 携带 Secure 标记。
AUTH_COOKIE_SECURE=false

# 前端覆盖项；留空让 Web 端从 AUTH_ENABLED 自动派生——start_web.py 已经
# 把 AUTH_ENABLED 同步到这里供 Next.js 中间件使用。
NEXT_PUBLIC_AUTH_ENABLED=

# --- 多用户配置（推荐） ---
# 当 AUTH_ENABLED=true 且未设置 AUTH_USERNAME / AUTH_PASSWORD_HASH 时，
# 在浏览器中访问 /register。第一位注册者自动成为管理员，可以在
# /admin/users 中管理其他用户；公开的 /register 端点会在管理员创建后
# 自动关闭。用户数据保存在 multi-user/_system/auth/users.json。

# --- 单用户环境变量配置（旧版 / 简单） ---
# 也可以直接设置 AUTH_USERNAME 与 AUTH_PASSWORD_HASH，该用户始终被视为
# 管理员。当 multi-user/_system/auth/users.json 已经存在时，它的优先级
# 高于这两个变量，这些设置会被忽略。

# 单用户模式下的管理员用户名。
AUTH_USERNAME=

# 密码的 Bcrypt 哈希，生成命令：
#   python -c "from deeptutor.services.auth import hash_password; print(hash_password('yourpassword'))"
AUTH_PASSWORD_HASH=

# ---------------------------------------------------------------------
# 8. PocketBase 边车（可选认证 + 存储）
# ---------------------------------------------------------------------
# POCKETBASE_URL 留空时使用内置的 SQLite/JSON 后端（默认）；填写后认证、
# 会话、知识库存储都改走 PocketBase。
#
# 通过 docker compose 启动时，PocketBase 容器始终会启动；只有这里填了
# POCKETBASE_URL，后端才会真正使用它。
#
# 注意：PocketBase 模式当前仅支持单用户。默认 schema 的 users 表没有
# `role` 字段（所有登录都解析为 role=user，无法创建 admin），并且
# session/message/turn 查询也不会按 user_id 过滤。多用户部署必须留空，
# 使用默认的 JSON/SQLite 后端。
#
#   本地 Docker：  POCKETBASE_URL=http://pocketbase:8090
#   本地裸机：    POCKETBASE_URL=http://localhost:8090
POCKETBASE_URL=

# Python 后端用于管理 PocketBase 集合的管理员账号。在 PocketBase UI 中
# 创建管理员之后再填这两项。
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# 远程服务器部署时，OAuth 重定向使用的 PocketBase 公网 URL。本机
# 浏览器访问 Docker 时留空即可。
POCKETBASE_EXTERNAL_URL=

# ---------------------------------------------------------------------
# 9. 附件存储（可选）
# ---------------------------------------------------------------------
# 聊天运行时会把用户上传的 PDF、DOCX、图片等文件持久化到这里，方便
# 预览抽屉在内存 base64 被释放后仍能重新读取原文件。
#
# 默认路径为 <project>/data/user/workspace/chat/attachments；
# docker-compose.yml 已经把对应目录挂载为持久化 volume。普通 Docker /
# Linux 部署留空即可。只有在多个后端实例共用共享存储（例如 NFS）时才
# 需要覆盖。
CHAT_ATTACHMENT_DIR=
